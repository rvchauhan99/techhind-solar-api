{
    "info": {
        "name": "TechHind Solar API - Fabrication & Installation",
        "description": "Postman collection covering all APIs related to completing the fabrication and installation processes, separated by tabs.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Fabrication",
            "item": [
                {
                    "name": "Listing: Pending Fabrication",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/order/fabrication-installation?page=1&limit=10&tab=pending_fabrication",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "order",
                                "fabrication-installation"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                },
                                {
                                    "key": "tab",
                                    "value": "pending_fabrication"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Listing: Completed Fabrication (Last 15 days)",
