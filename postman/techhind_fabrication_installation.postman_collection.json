                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"completed\",\n  \"remarks\": \"Fabrication is complete\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/order/:id/fabrication",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "order",
                                ":id",
                                "fabrication"
                            ],
                            "variable": [
