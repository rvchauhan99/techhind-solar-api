    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "pm.request.headers.add({key: 'x-tenant-id', value: pm.collectionVariables.get('tenant_key')});",
                    "pm.request.headers.add({key: 'x-tenant-key', value: pm.collectionVariables.get('tenant_key')});"
                ],
                "packages": {}
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "accessToken",
            "value": "YOUR_ACCESS_TOKEN",
            "type": "string"
        },
        {
            "key": "tenant_key",
            "value": "demo",
            "type": "string"
        },
        {
            "key": "orderId",
            "value": "1",
            "type": "string"
