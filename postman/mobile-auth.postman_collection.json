{
  "info": {
    "_postman_id": "5c2f8c7a-7b9a-4c1f-9a21-111111111111",
    "name": "TechHind Solar API - Mobile Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth, password, and profile flows for TechHind Solar mobile clients (multi-tenant, token-based)."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "tenantSubdomain",
      "value": "demo-tenant",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tempToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "email",
      "value": "user@example.com",
      "type": "string"
    },
    {
      "key": "otp",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth / Login & Tokens",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"your-password\",\n  \"tenant_key\": \"your-tenant-key-if-required\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login with email, password, and optional tenant_key (required in shared multi-tenant mode).\n\nOn success without 2FA: returns accessToken + refreshToken.\nOn success with 2FA enabled: returns require_2fa=true + tempToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.response || pm.response.code !== 200) {",
                  "  console.log('Login failed or non-200 response');",
                  "  return;",
                  "}",
                  "",
                  "let json;",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (e) {",
                  "  console.log('Response is not JSON');",
                  "  return;",
                  "}",
                  "",
                  "if (json.accessToken && json.refreshToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.unset('tempToken');",
                  "  console.log('Stored accessToken and refreshToken from login');",
                  "} else if (json.require_2fa && json.tempToken) {",
                  "  pm.collectionVariables.set('tempToken', json.tempToken);",
                  "  console.log('2FA required; tempToken stored. Call /auth/verify-2fa next.');",
                  "} else {",
                  "  console.log('Unexpected login response shape', json);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify 2FA",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tempToken\": \"{{tempToken}}\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-2fa",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-2fa"
              ]
            },
            "description": "Complete login when 2FA is enabled.\n\nUse the tempToken returned by /auth/login and the one-time 2FA code from the authenticator app."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.response || pm.response.code !== 200) {",
                  "  console.log('2FA verification failed or non-200 response');",
                  "  return;",
                  "}",
                  "",
                  "let json;",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (e) {",
                  "  console.log('Response is not JSON');",
                  "  return;",
                  "}",
                  "",
                  "if (json.accessToken && json.refreshToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.unset('tempToken');",
                  "  console.log('Stored accessToken and refreshToken from 2FA verification');",
                  "} else {",
                  "  console.log('Unexpected 2FA response shape', json);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh-token"
              ]
            },
            "description": "Exchange a valid refreshToken for a new access token.\n\nCall this when the API returns 401 due to an expired access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.response || pm.response.code !== 200) {",
                  "  console.log('Refresh token request failed or non-200 response');",
                  "  return;",
                  "}",
                  "",
                  "let json;",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (e) {",
                  "  console.log('Response is not JSON');",
                  "  return;",
                  "}",
                  "",
                  "if (json.newAccessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.newAccessToken);",
                  "  console.log('Updated accessToken from /auth/refresh-token');",
                  "} else {",
                  "  console.log('Unexpected refresh-token response shape', json);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Invalidate the current access token and log out the user."
          }
        }
      ]
    },
    {
      "name": "Auth / Password",
      "item": [
        {
          "name": "Change Password (self)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"old-password\",\n  \"new_password\": \"new-password\",\n  \"confirm_password\": \"new-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "change-password"
              ]
            },
            "description": "Change the current user's password. Requires a valid access token."
          }
        },
        {
          "name": "Forgot Password (send OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password"
              ]
            },
            "description": "Initiate password reset. If the email exists, an OTP will be sent. Response is generic to avoid email enumeration."
          }
        },
        {
          "name": "Verify Reset OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-reset-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-reset-otp"
              ]
            },
            "description": "Verify the OTP sent to the user's email before resetting the password."
          }
        },
        {
          "name": "Reset Password with OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\",\n  \"new_password\": \"new-password\",\n  \"confirm_password\": \"new-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "reset-password"
              ]
            },
            "description": "Reset the user's password using a valid OTP."
          }
        }
      ]
    },
    {
      "name": "Auth / Profile & 2FA",
      "item": [
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Fetch the current authenticated user's profile including role, status, and module permissions."
          }
        },
        {
          "name": "2FA - Generate Secret",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issuer\": \"TechHindSolar\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/2fa/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "2fa",
                "generate"
              ]
            },
            "description": "Generate a 2FA secret and QR code URL for the current user."
          }
        },
        {
          "name": "2FA - Enable",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/2fa/enable",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "2fa",
                "enable"
              ]
            },
            "description": "Enable 2FA for the current user by verifying a TOTP code generated from the secret."
          }
        },
        {
          "name": "2FA - Disable",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/2fa/disable",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "2fa",
                "disable"
              ]
            },
            "description": "Disable 2FA for the current user."
          }
        }
      ]
    },
    {
      "name": "User Master / Profile (optional)",
      "item": [
        {
          "name": "Get Current User Profile (User Master)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user-master/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user-master",
                "profile"
              ]
            },
            "description": "Alternative profile endpoint from user-master module, generally for admin/internal use."
          }
        }
      ]
    }
  ]
}

