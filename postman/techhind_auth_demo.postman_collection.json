{
    "info": {
        "name": "TechHind Solar API - Auth & Profile (demo tenant)",
        "description": "Postman collection covering login, profile, 2FA, and all password-related APIs using variables.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const responseData = pm.response.json();",
                                    "if (responseData && responseData.data && responseData.data.accessToken) {",
                                    "    pm.collectionVariables.set(\"accessToken\", responseData.data.accessToken);",
                                    "}",
                                    "if (responseData && responseData.data && responseData.data.twoFactorRequired) {",
                                    "    pm.collectionVariables.set(\"tempToken\", responseData.data.tempToken);",
                                    "}"
                                ],
                                "type": "text/javascript",
                                "packages": {}
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"{{loginUsername}}\",\n  \"password\": \"{{loginPassword}}\",\n  \"tenant_key\": \"{{tenant_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Verify 2FA",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const responseData = pm.response.json();",
                                    "if (responseData && responseData.data && responseData.data.accessToken) {",
                                    "    pm.collectionVariables.set(\"accessToken\", responseData.data.accessToken);",
                                    "}"
                                ],
                                "type": "text/javascript",
                                "packages": {}
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"tempToken\": \"{{tempToken}}\",\n  \"otp\": \"{{twoFactorOtp}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/verify-2fa",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "verify-2fa"
                            ]
                        }
                    }
                },
                {
                    "name": "Generate 2FA",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/2fa/generate",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "2fa",
                                "generate"
                            ]
                        }
                    }
                },
                {
                    "name": "Enable 2FA",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"password\": \"{{loginPassword}}\",\n  \"otp\": \"{{twoFactorOtp}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/2fa/enable",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "2fa",
                                "enable"
                            ]
                        }
                    }
                },
                {
                    "name": "Disable 2FA",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"password\": \"{{loginPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/2fa/disable",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "2fa",
                                "disable"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Auth Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "profile"
                            ]
                        }
                    }
                },
                {
                    "name": "Change Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"oldPassword\": \"{{loginPassword}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/change-password",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "change-password"
                            ]
                        }
                    }
                },
                {
                    "name": "Forgot Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"tenant_key\": \"{{tenant_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/forgot-password",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "forgot-password"
                            ]
                        }
                    }
                },
                {
                    "name": "Verify Reset OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"otp\": \"{{resetOtp}}\",\n  \"tenant_key\": \"{{tenant_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/verify-reset-otp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "verify-reset-otp"
                            ]
                        }
                    }
                },
                {
                    "name": "Reset Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"otp\": \"{{resetOtp}}\",\n  \"newPassword\": \"{{newPassword}}\",\n  \"tenant_key\": \"{{tenant_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/reset-password",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "reset-password"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "User Master",
            "item": [
                {
                    "name": "Get User Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/user-master/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "user-master",
                                "profile"
                            ]
                        }
                    }
                },
                {
                    "name": "Set Password (Admin)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"password\": \"{{adminSetPassword}}\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/user-master/:id/set-password",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "user-master",
                                ":id",
                                "set-password"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "{{targetUserId}}"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "pm.request.headers.add({key: 'x-tenant-id', value: pm.collectionVariables.get('tenant_key')});",
                    "pm.request.headers.add({key: 'x-tenant-key', value: pm.collectionVariables.get('tenant_key')});"
                ],
                "packages": {}
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "tenant_key",
            "value": "demo",
            "type": "string"
        },
        {
            "key": "loginUsername",
            "value": "testuser",
            "type": "string"
        },
        {
            "key": "loginPassword",
            "value": "testpassword",
            "type": "string"
        },
        {
            "key": "userEmail",
            "value": "user@example.com",
            "type": "string"
        },
        {
            "key": "newPassword",
            "value": "newpassword123",
            "type": "string"
        },
        {
            "key": "resetOtp",
            "value": "123456",
            "type": "string"
        },
        {
            "key": "targetUserId",
            "value": "1",
            "type": "string"
        },
        {
            "key": "adminSetPassword",
            "value": "newPasswordAdminSet",
            "type": "string"
        },
        {
            "key": "tempToken",
            "value": "",
            "type": "string"
        },
        {
            "key": "twoFactorOtp",
            "value": "123456",
            "type": "string"
        }
    ]
}