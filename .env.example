# Copy to .env and fill in values. Do not commit .env or real secrets.
#
# Deployment modes:
#   Dedicated (single-tenant): Do NOT set TENANT_REGISTRY_DB_URL. Required: DB_*, JWT_SECRET_*, NODE_ENV. Optional: DEDICATED_TENANT_ID, DB_POOL_*, DB_SSL_*.
#   Shared (multi-tenant):     Set TENANT_REGISTRY_DB_URL and MASTER_ENCRYPTION_KEY. Required: DB_*, JWT_SECRET_*, Registry URL, encryption key. Optional: ADMIN_API_KEY, DB_POOL_*, REGISTRY_DB_POOL_MAX.

# Server
NODE_ENV=production
PORT=9090
FRONTEND_URL=https://your-frontend.com

# DB query logs (main, tenant, registry). Default: disabled.
# ENABLE_AUDIT_LOGS=true

# Database – use either DATABASE_URL or DB_* vars
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASS=your-db-password

# DB SSL (production: Digital Ocean, Aiven, etc.). Required when NODE_ENV=production for managed Postgres.
# Option 1 – path to CA file (.crt or .pem), relative to project root. Place your provider's CA cert in src/config/.
# DB_SSL_CA_PATH=./src/config/ca-certificate.crt
# Option 2 – inline PEM (paste full cert with newlines as \n).
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Connection pool: keep low for managed Postgres (DigitalOcean, Aiven, etc.) to avoid
# "remaining connection slots are reserved for roles with the SUPERUSER attribute".
# You can set per-pool knobs:
# - MAIN_DB_POOL_MAX: main app DB pool (preferred)
# - TENANT_DB_POOL_MAX: per-tenant DB pool in shared mode (preferred)
# - REGISTRY_DB_POOL_MAX: registry DB pool (preferred)
# Backward compatible (applies when MAIN_/TENANT_ not set): DB_POOL_MAX, DB_POOL_MIN, DB_POOL_*
#
# When cloud and local both use the SAME DB: set small pool values for local dev so combined usage fits the limit.
# Stop the API on all instances before running npm run db:release-connections. Avoid killing the process with SIGKILL (kill -9); use Ctrl+C or SIGTERM so connections close on exit.
# MAIN_DB_POOL_MAX=5
# TENANT_DB_POOL_MAX=2
# DB_POOL_MAX=5
# DB_POOL_MIN=0

# Auth
JWT_SECRET_ACCESS_TOKEN=your-secret
JWT_SECRET_REFRESH_TOKEN=your-secret
# Optional: access token expiry (e.g. 7d, 15m). Default in code is 7d.
# JWT_ACCESS_TOKEN_EXPIRY=7d
# 2FA issuer (authenticator app label). Frontend sends hostname; fallback when missing: APP_DOMAIN (e.g. techhind.in) -> tenant_key.techhind.in; or APP_2FA_ISSUER for single fallback.
# APP_DOMAIN=techhind.in
# APP_2FA_ISSUER=myapp.com

# Multi-tenant (shared mode): set when running one app for multiple tenants.
# Total connections ≈ (main pool) + (registry pool) + (per-tenant pool × resident tenant pools) + (PDF worker/child process pools)
# TENANT_REGISTRY_DB_URL=postgres://user:pass@host:5432/registry_db
# MASTER_ENCRYPTION_KEY=32-byte-hex-or-long-secret-for-tenant-credentials
# REGISTRY_DB_POOL_MAX=1
# Limit how many tenant pools can be resident in-memory at once (LRU eviction). Helps keep total connections bounded.
# DB_GLOBAL_TENANT_POOL_LIMIT=6

# Dedicated mode: single tenant per app. Optional tenant id for JWT.
# DEDICATED_TENANT_ID=optional-uuid

# Admin API (optional): key for Tenant Management UI. Send as Authorization: Bearer <key> or x-admin-api-key.
# ADMIN_API_KEY=

# Bucket (S3-compatible: R2, Spaces, etc.)
# BUCKET_ENDPOINT=...
# BUCKET_NAME=...
# BUCKET_ACCESS_KEY_ID=...
# BUCKET_SECRET_ACCESS_KEY=...
# BUCKET_REGION=auto

# Quotation PDF generation (stability and rollout)
# Concurrency and memory: cap concurrent Chromium page renders to avoid OOM (default 2).
# On 1GB app (e.g. DigitalOcean): use PDF_RENDER_MAX_CONCURRENCY=1 so only one Chromium page runs at a time.
# PDF_RENDER_MAX_CONCURRENCY=2
# Queue backend:
# - memory: in-process queue (fallback / rollback)
# - redis: external queue, use with worker service
# PDF_QUEUE_BACKEND=memory
# REDIS_URL=redis://127.0.0.1:6379
# Optional canary list for redis backend (comma-separated tenant IDs). Empty = all tenants.
# PDF_QUEUE_CANARY_TENANT_IDS=
# Legacy toggle retained for backward compatibility:
# PDF_QUEUE_ENABLED=false
# PDF_QUEUE_WORKER_CONCURRENCY=1
# PDF_QUEUE_NAME=quotation-pdf
# PDF_QUEUE_JOB_TIMEOUT_MS=120000
# Worker deployment flag (operational): true in worker process, false in API process.
# PDF_WORKER_ENABLED=false
# Cache: count and TTL (default 50 entries, 15 min TTL). Set PDF_CACHE_MAX_BYTES to cap by memory (bytes).
# PDF_CACHE_MAX=50
# PDF_CACHE_TTL_MS=900000
# PDF_CACHE_MAX_BYTES=0
# Image fetch: timeout and max size for URL images (default 15s, 5MB).
# PDF_IMAGE_FETCH_TIMEOUT_MS=15000
# PDF_IMAGE_FETCH_MAX_BYTES=5242880
# Metrics: set PDF_METRICS_ENABLED=true to log [PDF_METRICS] (timing, cache hit, queue depth, heap).
# PDF_METRICS_ENABLED=false
# Artifact serving:
# - buffer: API fetches artifact and streams PDF bytes
# - signed_url: API redirects to signed object URL
# PDF_ARTIFACT_MODE=buffer
# PDF_ARTIFACT_SIGNED_URL_TTL_SEC=300
# Warmup: set PDF_WARMUP_ENABLED=true to prefetch template images for active tenants at startup.
# On low-connection setups (e.g. DB_POOL_MAX=2), set PDF_WARMUP_ENABLED=false to avoid startup connection spike.
# PDF_WARMUP_ENABLED=false
# PDF_WARMUP_MAX_TENANTS=5

# Async in-app job mode (no Redis, no separate worker)
# PDF_ASYNC_MODE=true
# PDF_JOB_RUNNER_ENABLED=true
# PDF_JOB_RUNNER_POLL_MS=1000
# PDF_JOB_RUNNER_HEARTBEAT_MS=30000
# PDF_JOB_MAX_CONCURRENCY=1
# Retry contract recommendation (standard run + one retry):
# PDF_JOB_MAX_ATTEMPTS=2
# PDF_CHILD_TIMEOUT_MS=120000
# Additional buffer included in server-recommended frontend poll timeout.
# PDF_POLL_WINDOW_BUFFER_MS=5000
# Time after which a job in "processing" is considered stuck and requeued (default 60000 = 1 min). Lowers long polling when worker died/restarted.
# PDF_JOB_PROCESSING_STALE_MS=30000
# How often the runner runs stuck-job recovery (default 15000 = 15s).
# PDF_JOB_RECOVERY_INTERVAL_MS=15000
# Max stale processing jobs recovered per runner tick.
# PDF_JOB_STALE_RECOVERY_BATCH=20
# Periodic cleanup cadence for old job rows.
# PDF_JOB_CLEANUP_INTERVAL_MS=900000
# Retention windows for cleanup.
# PDF_JOB_FAILED_RETENTION_HOURS=72
# PDF_JOB_COMPLETED_RETENTION_HOURS=168

# Max total bytes for in-memory PDF buffer cache (evicts oldest when exceeded).
# PDF_CACHE_MAX_BYTES=52428800

# Max bytes per image fetched for PDF rendering (guards against huge assets).
# PDF_IMAGE_FETCH_MAX_BYTES=2097152

# Max in-memory queue depth for the in-process PDF queue backend (memory mode).
# PDF_QUEUE_MAX_DEPTH=20

# --- Low-connection (e.g. DigitalOcean) PDF ---
# Use when managed Postgres has a low connection limit (e.g. DigitalOcean 22).
# Example baseline for DO-22 (single API instance, registry+tenants on same cluster):
# MAIN_DB_POOL_MAX=2
# REGISTRY_DB_POOL_MAX=1
# TENANT_DB_POOL_MAX=1
# DB_GLOBAL_TENANT_POOL_LIMIT=6
# Keep PDF concurrency low:
# PDF_JOB_MAX_CONCURRENCY=1
# PDF_RENDER_MAX_CONCURRENCY=1
# Optional: only if the PDF runner runs in a separate dedicated process:
# PDF_RUNNER_CAN_EVICT_TENANT_POOLS=true
# PDF_JOB_RUNNER_POLL_MS=2000
# PDF_WARMUP_ENABLED=false

# --- Lightweight (PDFKit) renderer: avoid Chromium for listed templates ---
# For 1GB or connection-limited deployments: set PDF_LIGHTWEIGHT_RENDERER_ENABLED=true and
# PDF_LIGHTWEIGHT_RENDERER_TEMPLATE_KEYS=default (or comma-separated keys). Avoids Chromium for those templates; lower memory and CPU. Output is simplified layout.
# PDF_LIGHTWEIGHT_RENDERER_ENABLED=false
# PDF_LIGHTWEIGHT_RENDERER_TEMPLATE_KEYS=default

# --- Process memory (optional) ---
# If using PM2: set max_memory_restart (e.g. 500M) to avoid unbounded growth. For very heavy PDFs, the child can be run with Node --max-old-space-size if needed.

# Add other vars (GOOGLE_*, BREVO_*, etc.) as needed.
